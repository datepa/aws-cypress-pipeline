{
  "compilerOptions": {
    "target": "es6",
    "lib": ["es6", "dom"],
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "moduleResolution": "node10",
    "ignoreDeprecations": "6.0",
    "types": ["cypress"]

  },
  "include": ["**/*.ts"]
}